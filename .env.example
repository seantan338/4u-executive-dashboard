PORT=3000

# Frontend Firebase web app config (single-line JSON), injected into pages via /config.js
FIREBASE_CONFIG_JSON={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}

# Backend Firebase Admin service account (raw JSON or base64-encoded JSON)
FIREBASE_SA_JSON=

# Webhook secret for /webhook/progress (required to enable the webhook)
WEBHOOK_SECRET=
