PORT=3000

# 前端 Firebase web app config (单行 JSON)
FIREBASE_CONFIG_JSON={"apiKey":"xxx","authDomain":"xxx.firebaseapp.com","projectId":"xxx","storageBucket":"xxx.appspot.com","messagingSenderId":"xxx","appId":"xxx"}

# 后端 Service Account (base64 或原始 JSON, 从 Firebase Console 下载)
FIREBASE_SA_JSON=这里放 base64 或 JSON 字符串

# Webhook 安全 key (随便设一个强随机字符串)
WEBHOOK_SECRET=your-super-secret-key-here